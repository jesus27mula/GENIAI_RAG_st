# Alternativa local a `.streamlit/secrets.toml`.
GOOGLE_API_KEY=pega_aqui_tu_clave_de_google_ai_studio

# Configuración opcional.
CHROMA_COLLECTION_NAME=rag_fiscal_startups
VECTORSTORE_DIR=data/vectorstore/chroma
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CHAT_MODEL=gemini-2.5-flash

RETRIEVAL_K=4
PRIORITY_K_PER_SOURCE=2
MAX_DOC_CHARS=1400
MAX_CONTEXT_CHARS=5000
MAX_AGENT_OUTPUT_TOKENS=500
THINKING_BUDGET=0
MODEL_TEMPERATURE=0.2
MODEL_TIMEOUT_SECONDS=60
